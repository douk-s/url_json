[
  // 当前版本可直接导入的统一配置示例
  // 已合并：HTML/CSS、HTML/XPath、苹果CMS JSON、苹果CMS XML 等来源
  // 苹果CMS 类源统一映射为：ui.search -> ui.detail -> ui.video.play
  // 说明：保留少量手写示例，其余 api/config.json5 条目已批量转换并合并


    {
      "name": "星巴资源站",
      "baseUrl": "https://json.xingba222.com",
      "request": {
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
        }
      },
      "pages": {
        "ui.search": {
          "list": {
            "vars": {
              "keyword": {
                "fromInput": "keyword"
              },
              "page": {
                "init": 1
              }
            },
            "request": {
              "url": "/api.php/provide/vod/",
              "method": "GET",
              "query": {
                "ac": "detail",
                "wd": "{{keyword}}",
                "pg": "{{page}}"
              }
            },
            "response": {
              "format": "json",
              "engine": "jsonpath",
              "list": "$.list[*]",
              "fields": {
                "id": "vod_id",
                "title": "vod_name",
                "cover": "vod_pic",
                "subtitle": "vod_remarks",
                "category": "type_name"
              }
            },
            "update": {
              "page": {
                "add": [
                  "page",
                  1
                ]
              }
            },
            "open": "ui.detail"
          }
        },
        "ui.detail": {
          "info": {
            "request": {
              "url": "/api.php/provide/vod/",
              "method": "GET",
              "query": {
                "ac": "detail",
                "ids": "{{ui.search.list.id}}"
              }
            },
            "response": {
              "format": "json",
              "engine": "jsonpath",
              "item": "$.list[0]",
              "fields": {
                "title": "vod_name",
                "cover": "vod_pic",
                "category": "type_name",
                "year": "vod_year",
                "area": "vod_area",
                "director": "vod_director",
                "actor": "vod_actor",
                "summary": "vod_content",
                "subtitle": "vod_remarks"
              }
            }
          },
          "episodes": {
            "request": {
              "reuse": "info"
            },
            "response": {
              "format": "json",
              "engine": "embeddedPlaylist",
              "item": "$.list[0]",
              "lineField": "vod_play_from",
              "itemsField": "vod_play_url",
              "lineSplit": "$$$",
              "itemSplit": "#",
              "pairRegex": "([^$#]+)\\$([^$#]+)",
              "fields": {
                "title": "itemName",
                "url": "itemUrl"
              }
            }
          }
        },
        "ui.video.play": {
          "content": {
            "response": {
              "format": "text"
            },
            "output": {
              "kind": "media",
              "field": "{{ui.detail.episodes.url}}"
            }
          }
        }
      }
    },
    {
      "name": "小纸鸢资源站 (XML)",
      "baseUrl": "https://hsckzy001.com",
      "request": {
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
        }
      },
      "pages": {
        "ui.search": {
          "list": {
            "vars": {
              "keyword": {
                "fromInput": "keyword"
              },
              "page": {
                "init": 1
              }
            },
            "request": {
              "url": "/api.php/provide/vod/at/xml",
              "method": "GET",
              "query": {
                "ac": "detail",
                "wd": "{{keyword}}",
                "pg": "{{page}}"
              }
            },
            "response": {
              "xmlMode": "toObject",
              "format": "xml",
              "engine": "jsonpath",
              "list": "$.list.video[*]",
              "fields": {
                "id": "id",
                "title": "name",
                "cover": "pic",
                "subtitle": "note",
                "category": "type"
              }
            },
            "update": {
              "page": {
                "add": [
                  "page",
                  1
                ]
              }
            },
            "open": "ui.detail"
          }
        },
        "ui.detail": {
          "info": {
            "request": {
              "url": "/api.php/provide/vod/at/xml",
              "method": "GET",
              "query": {
                "ac": "detail",
                "ids": "{{ui.search.list.id}}"
              }
            },
            "response": {
              "xmlMode": "toObject",
              "format": "xml",
              "engine": "jsonpath",
              "item": "$.list.video[0]||$.list.video",
              "fields": {
                "title": "name",
                "cover": "pic",
                "category": "type",
                "year": "year",
                "area": "area",
                "director": "director",
                "actor": "actor",
                "summary": "des",
                "subtitle": "note"
              }
            }
          },
          "episodes": {
            "request": {
              "reuse": "info"
            },
            "response": {
              "xmlMode": "toObject",
              "format": "xml",
              "engine": "embeddedPlaylist",
              "lineField": "_play_from",
              "itemsField": "_play_url",
              "lineSplit": "$$$",
              "itemSplit": "#",
              "pairRegex": "([^$#]+)\\$([^$#]+)",
              "fields": {
                "title": "itemName",
                "url": "itemUrl"
              }
            }
          }
        },
        "ui.video.play": {
          "content": {
            "response": {
              "format": "text"
            },
            "output": {
              "kind": "media",
              "field": "{{ui.detail.episodes.url}}"
            }
          }
        }
      }
    },
    {
      "name": "欧乐影院 XPath测试",
      "baseUrl": "https://cn.xgcartoon.com",
      "request": {
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/114.0.0.0 Safari/537.36",
          "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
          "Accept-Language": "en-US,en;q=0.5",
          "Connection": "keep-alive"
        },
        "charset": "UTF-8"
      },
      "pages": {
        "ui.search": {
          "list": {
            "vars": {
              "keyword": {
                "fromInput": "keyword"
              },
              "page": {
                "init": 1
              }
            },
            "request": {
              "url": "/search",
              "method": "GET",
              "query": {
                "q": "{{keyword}}"
              }
            },
            "response": {
              "format": "html",
              "engine": "xpath",
              "list": "//*[contains(concat(' ', normalize-space(@class), ' '), ' topic-list-box ')]",
              "fields": {
                "title": ".//*[contains(concat(' ', normalize-space(@class), ' '), ' topic-list-item__info ')]//*[contains(concat(' ', normalize-space(@class), ' '), ' h3 ')]/text()",
                "detailUrl": {
                  "rule": ".//a/@href",
                  "asUrl": true
                },
                "cover": {
                  "rule": ".//amp-img/@src",
                  "asUrl": true
                },
                "subtitle": ".//*[contains(concat(' ', normalize-space(@class), ' '), ' topic-list-item--author ')]/text()"
              }
            },
            "update": {
              "page": {
                "add": [
                  "page",
                  1
                ]
              }
            },
            "open": "ui.detail"
          }
        },
        "ui.detail": {
          "info": {
            "request": {
              "url": "{{ui.search.list.detailUrl}}",
              "method": "GET"
            },
            "response": {
              "format": "html",
              "engine": "xpath",
              "item": "$",
              "fields": {
                "title": "//*[contains(concat(' ', normalize-space(@class), ' '), ' detail-right__title ')]/h1/text()",
                "playEntryUrl": {
                  "rule": "//*[contains(concat(' ', normalize-space(@class), ' '), ' detail-sider-btns ')]//a/@href",
                  "asUrl": true
                },
                "cover": {
                  "rule": "//*[contains(concat(' ', normalize-space(@class), ' '), ' detail-sider ')]//amp-img/@src",
                  "asUrl": true
                }
              }
            }
          },
          "episodes": {
            "request": {
              "url": "{{ui.search.list.detailUrl}}",
              "method": "GET"
            },
            "response": {
              "format": "html",
              "engine": "xpath",
              "list": "//*[contains(concat(' ', normalize-space(@class), ' '), ' col-xl-3 ') and contains(concat(' ', normalize-space(@class), ' '), ' col-lg-4 ') and contains(concat(' ', normalize-space(@class), ' '), ' col-md-4 ') and contains(concat(' ', normalize-space(@class), ' '), ' col-sm-6 ') and contains(concat(' ', normalize-space(@class), ' '), ' col-xs-6 ') and contains(concat(' ', normalize-space(@class), ' '), ' col-6 ')]",
              "fields": {
                "title": ".//a/@title",
                "url": {
                  "rule": ".//a/@href",
                  "asUrl": true
                }
              }
            }
          }
        },
        "ui.video.play": {
          "content": {
            "request": {
              "url": "{{ui.detail.info.playEntryUrl}}",
              "method": "GET"
            },
            "response": {
              "format": "html",
              "engine": "xpath",
              "item": "$",
              "fields": {
                "candidateUrl": "//video/@src||//source/@src"
              }
            },
            "output": {
              "kind": "media",
              "field": "candidateUrl",
              "sniff": {
                "include": [
                  ".m3u8",
                  ".mp4"
                ],
                "exclude": [
                  "hm.baidu.com",
                  "google-analytics.com"
                ]
              }
            }
          }
        }
      }
    },
